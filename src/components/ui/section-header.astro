---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  class?: string;
}

const { badge, title, subtitle, class: className = '' } = Astro.props;
---

<div class={`text-center mb-12 ${className}`}>
  {badge && (
    <span class="inline-block px-4 py-1.5 mb-4 text-sm font-medium text-brand-red bg-brand-red/10 border border-brand-red/20 rounded-full">
      {badge}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl font-bold font-heading mb-4">
    {title}
  </h2>
  {subtitle && (
    <p class="text-text-secondary text-lg max-w-2xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
