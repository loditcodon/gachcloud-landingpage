---
interface Props {
  class?: string;
  hover?: boolean;
}

const { class: className = '', hover = true } = Astro.props;

const hoverClasses = hover
  ? 'hover:border-brand-red/50 hover:shadow-lg hover:shadow-brand-red/5 transition-all duration-300'
  : '';
---

<div class={`bg-surface border border-border rounded-xl p-6 ${hoverClasses} ${className}`}>
  <slot />
</div>
